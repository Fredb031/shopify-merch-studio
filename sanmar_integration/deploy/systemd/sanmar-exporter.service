[Unit]
Description=SanMar Prometheus exporter
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sanmar
WorkingDirectory=/opt/sanmar
EnvironmentFile=/opt/sanmar/.env
ExecStart=/opt/sanmar/.venv/bin/python -m sanmar metrics --port 9100
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
